SECRET_KEY=replace-me-with-a-secure-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database: leave DATABASE_URL empty to use SQLite locally (default),
# or point it at a Postgres instance such as:
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
DB_NAME=db.sqlite3

# Email: default writes verification emails to the runserver console.
# Swap to SMTP in production (Resend, SendGrid, Mailgun, SES, etc.).
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=BudgetFlow <noreply@budgetflow.local>
FRONTEND_BASE_URL=http://localhost:5173
